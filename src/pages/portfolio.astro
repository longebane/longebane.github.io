        image: mtrImage,
        bullets: [
            'Responsive Design with Bootstrap, Expression Engine, Calendar and Events.',
        ],
    },
    {
        title: 'Kinetic Personnel Group',
        category: 'Agency',
        href: 'https://www.kineticpersonnelgroup.com/',
        image: kineticImage,
        descriptionSnippet:
            'Full service staffing firm specializing in professional staffing solutions.',
        bullets: ['MojoMotor Engine integration.'],
    },
    {
        title: 'SeaExpress App',
        category: 'Government',
        href: '#',
        image: seaImage,
        bullets: ['Mobile, IU, Project Management.'],
    },
    {
        title: 'Center on Philanthropy',
        category: 'Non-profit',
