---

<BaseLayout
    title='Web Portfolio | StudioDao: The Works of Long Dao'
    description='View the web development portfolio of Long Dao, showcasing projects in frontend architecture, React, TypeScript, D3.js, and AI-powered investigative platforms.'
    bodyClass='web-portfolio'
>
    <article
        class='portfolio-article'
        itemscope
        itemtype='http://schema.org/CreativeWork'
    >
        <h1 class='page-header'>Engineering</h1>
        <p class='intro-description'>
            Technical leadership and frontend architecture — delivering AI
            investigative platforms for state agencies and high-security cloud
            storage at enterprise scale.
        </p>
        <div class='portfolio-container'>
            {
                featuredProjects.map((project) => (
                    <ProjectCard {...project} isCondensed={false} />
                ))
            }

            <div class='secondary-grid'>
                {
                    secondaryProjects.map((project) => (
                        <ProjectCard {...project} isCondensed={true} />
                    ))
                }
            </div>
        </div>
    </article>
</BaseLayout>
