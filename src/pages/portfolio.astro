    },
    {
        title: 'Environmental Systems Research Institute (ESRI)',
        category: 'Enterprise GIS',
        href: 'https://www.esri.com',
        image: esriImage,
        descriptionSnippet:
            'Global market leader in GIS software, location intelligence, and mapping.',
        bullets: [
            'Frontend development across the ArcGIS ecosystem using Angular, and JS.',
            'Architected a cross-functional design library featuring reusable web components and specialized spatial icons.',
        ],
    },
    {
        title: 'DoubleDoor.io',
        category: 'Real Estate',
        href: 'https://doubledoor.io/',
        image: ddImage,
        descriptionSnippet: 'Real estate technology platform.',
        bullets: [
            'Directed frontend technical strategy, aligning engineering architecture with business revenue goals.',
            'Established core CI/CD workflows, TDD standards, and rigorous code review protocols.',
            'Unified architecture patterns across frontend, backend, and design systems.',
