---
export interface Props {
    sections: {
        title: string
        type: string
    }[]
}

const { sections } = Astro.props

// Generate URL-safe IDs from titles
const generateId = (title: string) => {
    return title
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
}

const getIcon = (type: string) => {
    switch (type) {
        case 'original':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>`
        case 'album':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>`
        case 'arrangement':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><rect x="2" y="6" width="20" height="12" rx="2"></rect><path d="M6 12h4M8 10v4M15 11h.01M18 13h.01"></path></svg>`
        default:
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`
    }
}
---

<nav class='toc-container'>
    <div class='toc-header'>
        <svg
            class='toc-icon'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
        >
            <line x1='8' y1='6' x2='21' y2='6'></line>
            <line x1='8' y1='12' x2='21' y2='12'></line>
            <line x1='8' y1='18' x2='21' y2='18'></line>
            <line x1='3' y1='6' x2='3.01' y2='6'></line>
            <line x1='3' y1='12' x2='3.01' y2='12'></line>
            <line x1='3' y1='18' x2='3.01' y2='18'></line>
        </svg>
        <h3>Music Portfolio Sections</h3>
    </div>
    <ul class='toc-list'>
        {
            sections.map((section) => {
                const id = generateId(section.title)
                return (
                    <li>
                        <a href={`#${id}`} class='toc-link'>
                            <div
                                class='toc-icon-wrapper'
                                set:html={getIcon(section.type)}
                            />
                            <div class='toc-content'>
                                <span class='toc-type'>
                                    {section.type.toUpperCase()}
                                </span>
                                <span class='toc-title'>{section.title}</span>
                            </div>
                        </a>
                    </li>
                )
            })
        }
    </ul>
</nav>

<script>
    // Handle click for smooth scroll
    const links = document.querySelectorAll('.toc-link')
    links.forEach((link) => {
        link.addEventListener('click', (e) => {
            e.preventDefault()
            const href = link.getAttribute('href')
            if (!href?.startsWith('#')) return

            const targetId = href.substring(1)
            const target = document.getElementById(targetId)

            if (target) {
                const tocContainer = document.querySelector('.toc-container') as HTMLElement | null
                const tocHeight = tocContainer ? tocContainer.offsetHeight : 0
                const targetPosition = target.getBoundingClientRect().top + window.scrollY
                
                window.scrollTo({
                    top: targetPosition - tocHeight - 20,
                    behavior: 'smooth'
                })
                
                window.history.pushState(null, '', href)
            }
        })
    })
</script>

<style>
    .toc-container {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: #ffffff;
        border-bottom: none; /* Borders handled by items */
        border-radius: 0;
        padding: 0 3rem;
        margin: 0 -3rem 40px -3rem;
        width: auto;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05); /* Very subtle depth */
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .toc-header {
        display: none; /* Removed app-style header for cleaner archival look */
    }

    .toc-icon {
        width: 20px;
        height: 20px;
        color: var(--accent-blue);
        flex-shrink: 0;
    }

    .toc-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--accent-blue);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        border-top: 1px solid #121212;
        border-left: 1px solid #121212; /* Left boundary for the grid */
    }

    .toc-list li {
        border-right: 1px solid #121212;
        border-bottom: 1px solid #121212;
        background: #ffffff;
    }

    .toc-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 15px;
        color: #121212;
        text-decoration: none;
        height: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease;
    }

    .toc-link:hover {
        background-color: #f8f8f8;
        color: #1373aa;
    }

    .toc-link.active {
        background-color: #121212;
        color: #ffffff;
    }

    .toc-icon-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border: 1px solid #121212;
        border-radius: 0;
        color: #121212;
        background: #ffffff;
        flex-shrink: 0;
        transition: all 0.2s ease;
    }

    .toc-link.active .toc-icon-wrapper {
        background: #ffffff;
        color: #121212;
        border-color: #121212;
    }
    
    .toc-link.active .toc-title {
        color: #ffffff;
        font-weight: 700;
    }

    :global(.section-icon) {
        width: 18px;
        height: 18px;
    }

    .toc-content {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 0; /* prevent flex child from overflowing its container */
    }

    .toc-type {
        font-family: var(--font-sans);
        font-size: 7px;
        font-weight: 700;
        color: #666;
        letter-spacing: 0.5px;
        margin-bottom: 1px;
    }

    .toc-title {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 13px;
        font-weight: 500;
        line-height: 1;
        white-space: nowrap;
    }

    @media (max-width: 768px) {
        .toc-container {
            display: none;
        }
    }
</style>
