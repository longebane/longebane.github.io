---
// Contact Form Component (Formspree)
---

<div id="contact-modal" class="contact-modal" aria-hidden="true">
  <div class="contact-modal-content">
    <button class="close-button" id="close-modal" aria-label="Close contact form">&times;</button>
    <div class="modal-masthead">
      <h2 class="editorial-title">Reach Out</h2>
      <p class="category-marker">Inquiries & Notes</p>
    </div>
    
    <form action="https://formspree.io/f/mdapnerv" method="POST" class="editorial-form">
      <div class="input-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Who are you?" />
      </div>

      <div class="input-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="Where can I find you?" />
      </div>

      <div class="input-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="Say hello..."></textarea>
      </div>

      <button type="submit" class="submit-button">
        Send Message
        <span class="button-arrow">→</span>
      </button>
    </form>
  </div>
</div>

<button id="contact-button" class="contact-button">Contact</button>

<script>
  const modal = document.getElementById('contact-modal');
  const btn = document.getElementById('contact-button');
  const closeBtn = document.getElementById('close-modal');

  if (modal && btn && closeBtn) {
    const openModal = () => {
      modal.style.display = 'block';
      modal.setAttribute('aria-hidden', 'false');
      void modal.offsetWidth;
      modal.classList.add('is-visible');
    };

    const closeModal = () => {
      modal.classList.remove('is-visible');
      setTimeout(() => {
        if (!modal.classList.contains('is-visible')) {
          modal.style.display = 'none';
          modal.setAttribute('aria-hidden', 'true');
        }
      }, 400);
    };

    btn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);

    window.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeModal();
      }
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal.style.display === 'block') {
        closeModal();
      }
    });
  }
</script>

<style>
  .contact-button {
    position: fixed;
    left: 50%;
    bottom: 30px;
    transform: translateX(-50%);
    width: auto;
    min-width: 220px;
    background-color: #1373aa; /* Midnight Blue Accent */
    color: #fff;
    border: 1px solid #000;
    border-radius: 0;
    padding: 16px 40px;
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 8px 8px 0 #000;
    z-index: 1000;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    outline: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .contact-button:hover {
    background-color: #2b7fff;
    transform: translateX(-50%) translateY(-10px);
    box-shadow: 8px 18px 0 #000;
    letter-spacing: 5px;
  }

  .contact-modal {
    display: none;
    position: fixed;
    z-index: 2000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(252, 252, 252, 0.55); /* Elite high-transparency ivory vellum */
    backdrop-filter: blur(2px); /* Minimalist archival glass effect */
    transition: opacity 0.4s ease;
    opacity: 0;
  }

  .contact-modal.is-visible {
    opacity: 1;
  }

  .contact-modal-content {
    background-color: #ffffff;
    margin: 5% auto;
    padding: 40px;
    border: 12px double #121212; /* Signature editorial rule */
    width: 90%;
    max-width: 550px;
    border-radius: 0;
    position: relative;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.15);
    transform: translateY(30px) scale(0.98);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .is-visible .contact-modal-content {
    transform: translateY(0) scale(1);
  }

  .modal-masthead {
    text-align: center;
    border-bottom: 3px double #121212;
    padding-bottom: 20px;
    margin-bottom: 30px;
  }

  .editorial-title {
    font-family: "Chomsky", serif;
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 5px;
  }

  .category-marker {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--accent-primary);
  }

  .close-button {
    position: absolute;
    top: 15px;
    right: 15px;
    color: #121212;
    font-size: 32px;
    font-weight: 300;
    cursor: pointer;
    border: none;
    background: none;
    transition: transform 0.3s ease;
  }

  .close-button:hover {
    transform: rotate(90deg);
  }

  .editorial-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  label {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #121212;
  }

  input,
  textarea {
    padding: 12px;
    border: 1px solid #121212;
    border-radius: 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    background: #fcfcfc;
    transition: background 0.3s ease;
  }

  input:focus,
  textarea:focus {
    outline: none;
    background: #fff;
    border-color: var(--accent-primary);
    box-shadow: inset 0 0 0 1px var(--accent-primary);
  }

  .submit-button {
    margin-top: 10px;
    padding: 18px;
    background-color: #121212;
    color: white;
    border: 1px solid #121212;
    border-radius: 0;
    cursor: pointer;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .submit-button:hover {
    background-color: var(--accent-primary);
    border-color: var(--accent-primary);
    gap: 25px;
  }

  .button-arrow {
    font-size: 1.4rem;
    transition: transform 0.3s ease;
  }

  .submit-button:hover .button-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 600px) {
    .contact-modal-content {
      margin: 10% 15px;
      padding: 25px 20px;
      border-width: 8px;
    }

    .editorial-title {
      font-size: 2.2rem;
    }

    .contact-button {
      bottom: 20px;
      padding: 14px 25px;
      min-width: 160px;
      font-size: 14px;
    }
  }
</style>
</style>