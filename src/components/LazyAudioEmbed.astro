---
export interface Props {
    src: string
    title: string
    link: string
}

const { src, title, link } = Astro.props
---

<iframe
    class='soundcloud'
    width='100%'
    height='166'
    scrolling='no'
    frameborder='no'
    loading='lazy'
    src={src}
    title={title}
>
</iframe>

<style>
    iframe.soundcloud {
        border-radius: 0; /* NY Elite Chic Zero Radius */
    }
</style>
