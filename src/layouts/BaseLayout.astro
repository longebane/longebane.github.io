---
import "../assets/css/styles.css";
import ContactForm from "../components/ContactForm.astro";

export interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  image?: string;
  url?: string;
}

const { title, description, bodyClass = "", image = "/assets/img/logo.png", url = Astro.url } = Astro.props;
const isHome = Astro.url.pathname === "/";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO & Metadata -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Long Dao" />
    <meta name="theme-color" content="#13181d" />
    <link rel="canonical" href={url} />
    <meta name="keywords" content="Long Dao, Studio Dao, LongeBane, Game Music Composer, Soundtrack Design, Senior Frontend Engineer, React Architect, TypeScript Developer, Video Game Scoring, OST Composition, Immortal Defense, Saturated Dreamers" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={isHome ? "website" : "article"} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": isHome ? "Person" : "Article",
        "name": "Long Dao",
        "url": Astro.site,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": url
        },
        "description": description,
        "image": new URL(image, Astro.site),
        "author": {
          "@type": "Person",
          "name": "Long Dao"
        }
      })}>
    </script>

    <link href="https://fonts.googleapis.com/css?family=Lato:100,300,400" rel="stylesheet" type="text/css" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="Shortcut Icon" href="/favicon.ico" />
    
    <!-- Clarity -->
    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
        t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "w0q7vn1lf0");
    </script>
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-X2V8J3Y466"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-X2V8J3Y466");
    </script>
    
    <!-- SoundCloud Preload -->
    <link rel="preload" as="script" href="https://platform.soundcloud.com/widgets.js" />
    <script async defer src="https://platform.soundcloud.com/widgets.js"></script>
  </head>

  <body class={bodyClass}>
    <header class="site-header">
      <div class="header-content">
        <a href="/" class="site-title-container">
          <span class="site-title">Studio Dao: The Works of Long Dao</span>
        </a>
      </div>
      <nav id="filter" aria-label="Main Navigation">
        <ul>
          <li class={Astro.url.pathname === "/" ? "selected" : ""}>
            <a href="/" id="nav-music"><span>Music Portfolio</span></a>
          </li>
          <li class={Astro.url.pathname === "/" ? "" : "selected"}>
            <a href="/portfolio" id="nav-web"><span>Web Portfolio</span></a>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <ContactForm />
  </body>
</html>